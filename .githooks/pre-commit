#!/bin/bash
# Auto-deploy ft8-web/www/ → docs/ before each commit.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

bash deploy.sh

# Stage updated docs/ files (use -f to include new files ignored by docs/.gitignore)
git add -f docs/*.js docs/*.html docs/*.json docs/*.md 2>/dev/null || true
